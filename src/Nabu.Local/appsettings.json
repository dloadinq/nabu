{
  "NabuLocal": {
    "Url": "http://localhost:50000",
    "StatusHtmlPath": "Status.html",
    "Whisper": {
      "ModelsDirectory": "models",
      "Language": "english"
    },
    "Vad": {
      "ModelPath": "models/silero_vad.onnx",
      "Threshold": 0.75,
      "SamplingRate": 16000,
      "MinSpeechDurationMs": 250,
      "MinSilenceDurationMs": 1500,
      "SpeechPadMs": 30
    },
    "WakeWord": {
      "Model": "hey_jarvis_v0.1",
      "Threshold": 0.7,
      "StepFrames": 10
    }
  },
  "Embedding": {
    "Enabled": true,
    "ModelDirectory": "resources/embedding",
    "CommandDirectory": "resources/commands",
    "Threshold": 0.55,
    "MinConfidenceGap": 0.05,
    "HighConfidenceThreshold": 0.85
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
