<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:nabu="clr-namespace:Nabu.Maui;assembly=Nabu.Maui"
             x:Class="Nabu.MauiDemo.MainPage"
             Title="Nabu">

    <Grid RowDefinitions="*,Auto" Padding="32,24" RowSpacing="12">

        <nabu:NabuAssistantView Grid.Row="0"
                                ShowLanguageSelect="True"
                                TranscriptionReady="OnTranscriptionReady"/>

        <Button Grid.Row="1"
                Text="Change Model"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="8"
                HeightRequest="40"
                HorizontalOptions="End"
                Clicked="OnChangeModelClicked"/>
    </Grid>

</ContentPage>
