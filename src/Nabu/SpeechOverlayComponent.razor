@*
    SpeechOverlayComponent – thin Blazor wrapper around the shared speech-overlay CSS.
    
        --speech-overlay-bg          Backdrop colour           (default: rgba(0,0,0,0.65))
        --speech-overlay-blur        Backdrop blur              (default: 6px)
        --speech-dialog-bg           Dialog background          (default: rgba(20,20,40,0.95))
        --speech-dialog-radius       Border-radius              (default: 24px)
        --speech-dialog-max-width    Max dialog width           (default: 520px)
        --speech-dialog-padding      Dialog padding             (default: 2rem 2.5rem)
        --speech-dialog-font-family  Font family                (default: inherit)
        --speech-dialog-shadow       Box shadow                 (default: 0 25px 80px rgba(0,0,0,0.6))
        --speech-dialog-color        Text colour                (default: #fff)
        --speech-status-font-size    Status line font size      (default: 0.95rem)
        --speech-status-color        Status line colour         (default: rgba(255,255,255,0.55))
        --speech-highlight-color     Accent for "Done." etc.    (default: #4ade80)
        --speech-text-font-size      Transcription font size    (default: 1.2rem)
        --speech-preview-color       Live-preview text colour   (default: rgba(255,255,255,0.6))
        --speech-final-color         Final text colour          (default: rgba(255,255,255,0.75))
        --speech-visualizer-height   Visualizer height          (default: 280px)
*@

<link rel="stylesheet" href="/_content/Nabu/css/speech-overlay.css"/>

<div class="speech-overlay @CssClass" style="opacity:0;pointer-events:none" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {

    /// <summary>Additional CSS classes (e.g. "speech-overlay--active" to show the overlay).</summary>
    [Parameter]
    public string CssClass { get; set; } = "";

    /// <summary>Content rendered inside the overlay.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Unmatched attributes (e.g. id) passed to the root div.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

}
