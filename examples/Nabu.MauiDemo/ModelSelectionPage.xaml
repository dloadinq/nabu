<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nabu.MauiDemo.ModelSelectionPage"
             Title="Nabu — Model Setup"
             BackgroundColor="#0f0f0f">

    <Grid RowDefinitions="Auto,*,Auto" Padding="32,24">

        <!-- Header: GPU info -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <Label Text="Select Whisper Model"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"/>
            <Label x:Name="GpuLabel"
                   FontSize="13" TextColor="#888"/>
        </VerticalStackLayout>

        <!-- Model list -->
        <CollectionView Grid.Row="1"
                        x:Name="ModelList"
                        SelectionMode="Single"
                        SelectionChanged="OnModelSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,6"
                            Padding="18,14"
                            BackgroundColor="#1a1a1a"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#333"
                            StrokeThickness="1.5">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="Stroke" Value="#333"/>
                                        <Setter Property="BackgroundColor" Value="#1a1a1a"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="Stroke" Value="#4ade80"/>
                                        <Setter Property="BackgroundColor" Value="#162416"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding SizeLabel}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="White"/>
                                    <Border BackgroundColor="#2d5a2d"
                                            Padding="6,2"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            IsVisible="{Binding IsRecommended}">
                                        <Label Text="recommended" FontSize="10" TextColor="#4ade80"/>
                                    </Border>
                                    <Border BackgroundColor="#5a3a1a"
                                            Padding="6,2"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            IsVisible="{Binding RequiresForceCpu}">
                                        <Label Text="CPU only" FontSize="10" TextColor="#fb923c"/>
                                    </Border>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Description}"
                                       FontSize="12" TextColor="#888"/>
                                <Label Text="{Binding SizeInfo}"
                                       FontSize="11" TextColor="#555"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="✓"
                                   FontSize="20" TextColor="#4ade80"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding IsDownloaded}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer: options + action -->
        <VerticalStackLayout Grid.Row="2" Spacing="12" Margin="0,20,0,0">

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <CheckBox x:Name="ForceCpuCheck"
                          Color="#4ade80"
                          IsChecked="False"
                          CheckedChanged="OnForceCpuChanged"/>
                <Label Text="Force CPU mode (Q4 quantized)"
                       TextColor="#aaa" FontSize="13"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <ProgressBar x:Name="DownloadProgress"
                         Progress="0"
                         ProgressColor="#4ade80"
                         IsVisible="False"/>

            <Label x:Name="StatusLabel"
                   Text=""
                   FontSize="12" TextColor="#888"
                   IsVisible="False"/>

            <Button x:Name="StartButton"
                    Text="Download &amp; Start"
                    BackgroundColor="#16a34a"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="48"
                    IsEnabled="False"
                    Clicked="OnStartClicked"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
