@* Parent can wrap with data-whisper-forward-url="?handler=ForwardToAgent" to POST transcriptions *@
@code {
    [Parameter] public bool ShowLanguageSelect { get; set; }
}
<div class="whisper-vc-root">
@if (ShowLanguageSelect)
{
    <div class="text-center mb-3">
        <select id="whisperLanguageSelect" class="form-select w-auto d-inline-block mt-2">
            @foreach (var kvp in WhisperLanguages.Popular)
            {
                <option value="@kvp.Key">@kvp.Value</option>
            }
            <option disabled>───────────</option>
            @foreach (var kvp in WhisperLanguages.Extended)
            {
                <option value="@kvp.Key">@kvp.Value</option>
            }
        </select>
    </div>
}


<SpeechOverlayComponent id="vcOverlay">
    <div class="speech-dialog">
        <p id="vcOverlayStatus" class="speech-dialog__status"></p>
        <div id="visualizer" class="speech-visualizer"></div>
        <div class="speech-dialog__text">
            <span id="vcOverlayText"></span>
        </div>
        <div id="vcSendBtnContainer" class="speech-dialog__actions mt-3" style="display:none;">
            <button type="button" id="vcSendBtn" class="speech-dialog__send-btn">Send</button>
        </div>
    </div>
</SpeechOverlayComponent>
</div>

<script type="module">
    import { initApp, startOnUserGesture, setLanguage, finishRecording } from '/_content/Nabu.RCL/app.js';

    const langSelect = document.getElementById('whisperLanguageSelect');
    const overlay = document.getElementById('vcOverlay');
    const overlayStatus = document.getElementById('vcOverlayStatus');
    const overlayText = document.getElementById('vcOverlayText');
    const sendBtnContainer = document.getElementById('vcSendBtnContainer');
    const sendBtn = document.getElementById('vcSendBtn');

    function setProcessing(isProcessing) {
        if (langSelect) langSelect.disabled = isProcessing;
    }

    window.addEventListener('whisper:uiStateChanged', (uiStateEvent) => {
        const state = uiStateEvent.detail;
        if (!state) return;

        if (state.showOverlay) {
            overlay.classList.add('speech-overlay--active');
        } else {
            overlay.classList.remove('speech-overlay--active');
            const visualizer = document.getElementById('visualizer');
            if (visualizer) { visualizer.style.opacity = '1'; visualizer.style.maxHeight = ''; }
        }

        const highlightClass = (state.overlayStatus === 'Done.' || state.overlayStatus === 'Keyword detected!')
            ? ' speech-dialog__status--highlight' : '';
        const cancelClass = state.isCancelling ? ' speech-dialog__status--cancel' : '';

        overlayStatus.textContent = state.overlayStatus || '';
        overlayStatus.className = 'speech-dialog__status' + highlightClass + cancelClass;

        overlayText.textContent = state.overlayText || '';

        if (state.overlayText) {
            overlayText.className = state.isPreviewText ? 'speech-dialog__preview' : 'speech-dialog__final';
        } else {
            overlayText.className = '';
        }

        if (state.isCancelling) {
            const visualizer = document.getElementById('visualizer');
            if (visualizer) { visualizer.style.opacity = '0'; visualizer.style.maxHeight = '0'; }
        }

        if (sendBtnContainer) {
            sendBtnContainer.style.display = state.showSendButton ? 'block' : 'none';
        }

        setProcessing(state.isProcessing);
    });

    if (sendBtn) {
        sendBtn.addEventListener('click', async () => {
            sendBtn.disabled = true;
            try {
                await finishRecording();
            } finally {
                sendBtn.disabled = false;
            }
        });
    }

    if (langSelect) {
        try {
            const savedLang = localStorage.getItem('whisper_language');
            if (savedLang) langSelect.value = savedLang;
        } catch {}

        langSelect.addEventListener('change', () => {
            setLanguage(langSelect.value);
            try { localStorage.setItem('whisper_language', langSelect.value); } catch {}
        });

        const allOptions = [...langSelect.options];
        const separatorIdx = allOptions.findIndex(option => option.disabled && option.textContent.includes('───'));
        const extendedOptions = separatorIdx >= 0 ? allOptions.slice(separatorIdx) : [];

        function collapseLanguages() {
            if (extendedOptions.length === 0) return;
            const currentVal = langSelect.value;
            const isExtendedSelected = extendedOptions.some(option => option.value === currentVal && !option.disabled);
            if (isExtendedSelected) return;
            extendedOptions.forEach(option => option.style.display = 'none');
            let moreOpt = langSelect.querySelector('[data-more]');
            if (!moreOpt) {
                moreOpt = document.createElement('option');
                moreOpt.setAttribute('data-more', 'true');
                moreOpt.textContent = '⋯ More languages';
                moreOpt.value = '__more__';
                langSelect.appendChild(moreOpt);
            }
            moreOpt.style.display = '';
        }

        function expandLanguages() {
            extendedOptions.forEach(option => option.style.display = '');
            const moreOpt = langSelect.querySelector('[data-more]');
            if (moreOpt) moreOpt.style.display = 'none';
        }

        langSelect.addEventListener('change', () => {
            if (langSelect.value === '__more__') {
                expandLanguages();
                langSelect.value = 'english';
                langSelect.focus();
            }
        });

        const savedIsExtended = extendedOptions.some(option => option.value === langSelect.value && !option.disabled);
        if (savedIsExtended) {
            expandLanguages();
        } else {
            collapseLanguages();
        }
    }

    await initApp();
    await startOnUserGesture({ language: langSelect?.value ?? 'english' });
</script>
