{
  "WhisperLocal": {
    "Url": "http://localhost:50000",
    "StatusHtmlPath": "Status.html",
    "Whisper": {
      "GpuModelPath": "models/ggml-medium.bin",
      "CpuModelPath": "models/ggml-medium_q4.bin",
      "Language": "english"
    },
    "Vad": {
      "ModelPath": "resources/silero_vad.onnx",
      "Threshold": 0.75,
      "SamplingRate": 16000,
      "MinSpeechDurationMs": 250,
      "MinSilenceDurationMs": 1200,
      "SpeechPadMs": 30
    },
    "WakeWord": {
      "Model": "hey_jarvis_v0.1",
      "Threshold": 0.4,
      "StepFrames": 4
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}