@page
@model IndexModel
@{
    ViewData["Title"] = "Nabu Voice Assistant";
}

<div class="row w-100 h-100 justify-content-center align-items-center">
    <div class="col-12 col-md-8 mx-auto">
        <h1 class="display-4 text-center">Nabu Voice Assistant</h1>
        <nabu-assistant show-language-select="true"/>
        
        <div class="text-center">
            <p id="statusInfo" class="text-muted mt-1 mb-0 small" style="display:none"></p>
            <div id="backendInfo" class="small text-muted mt-1 mb-0">Active
                backend: @NabuConstants.BackendDetecting</div>
        </div>

        <div id="lastTranscriptionPanel" class="mt-3 p-3 bg-light border rounded" style="display:none">
            <small class="text-muted">Transcription:</small>
            <p id="lastTranscriptionText" class="mb-0 mt-1"></p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const TERMINATION_TEXT = '@NabuConstants.TerminationText';
        const NO_SPEECH_TEXT = '@NabuConstants.NoRecognizableSpeechText';
        const USER_CANCELLED_TEXT = '@NabuConstants.UserCancelledText';

        function handleTranscription(transcribedText) {
            if (!transcribedText) return;
            const transcriptionPanel = document.getElementById('lastTranscriptionPanel');
            const transcriptionTextElement = document.getElementById('lastTranscriptionText');
            if (transcriptionPanel && transcriptionTextElement) {
                transcriptionTextElement.textContent = transcribedText;
                transcriptionPanel.style.display = 'block';
            }

            if (transcribedText === TERMINATION_TEXT || transcribedText === NO_SPEECH_TEXT || transcribedText === USER_CANCELLED_TEXT) {
                const toastElement = document.getElementById('nabuToast');
                if (toastElement && typeof bootstrap !== 'undefined') {
                    document.getElementById('nabuToastBody').textContent = transcribedText;
                    new bootstrap.Toast(toastElement).show();
                }
            }
            fetch('?handler=ForwardToAgent', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({text: transcribedText})
            }).then(response => response.ok || console.warn('Forward failed:', response.status)).catch(error => console.warn(error));
        }

        window.addEventListener('nabu:transcriptionFinal', event => {
            const finalTranscriptionText = (event.detail || '').trim();
            if (finalTranscriptionText) handleTranscription(finalTranscriptionText);
        });
    </script>
}
